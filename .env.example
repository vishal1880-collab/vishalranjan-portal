# Public site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://vishalranjan.com

# Google AdSense publisher ID (e.g. ca-pub-1234567890123456). Leave blank to disable ads.
NEXT_PUBLIC_ADSENSE_CLIENT=

# Google Search Console verification token (just the content value, not the meta tag)
NEXT_PUBLIC_GSC_VERIFICATION=

# Vercel Postgres (auto-injected by Vercel on deploy; copy to local .env to test locally)
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=

# Admin API token. The MCP and any admin curl will pass this in `x-admin-token`.
# Generate with: openssl rand -base64 32
ADMIN_TOKEN=

# Optional: SMTP for sending the user a confirmation when their @vishalranjan.com is provisioned.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Vishal Ranjan <hello@vishalranjan.com>"
